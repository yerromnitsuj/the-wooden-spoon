<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <meta name="description" content="The Wooden Spoon — Simple recipes, real stories, honest food. A food blog by Sarah Chen.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <%- typeof head !== 'undefined' ? head : '' %>
</head>
<body>
  <!-- Navigation -->
  <nav class="nav">
    <div class="container nav-inner">
      <a href="/" class="nav-logo">
        <span class="nav-logo-icon">&#x1F944;</span>
        The Wooden Spoon
      </a>
      <div class="nav-links">
        <a href="/" class="nav-link<%= currentPath === '/' ? ' active' : '' %>">Recipes</a>
        <a href="/about" class="nav-link<%= currentPath === '/about' ? ' active' : '' %>">About</a>
      </div>
    </div>
  </nav>

  <!-- Main content -->
  <main>
    <%- body %>
  </main>

  <!-- Footer -->
  <footer class="footer">
    <div class="container">
      <div class="footer-inner">
        <div class="footer-brand">
          <span class="footer-logo">&#x1F944; The Wooden Spoon</span>
          <p class="footer-tagline">Simple recipes, real stories, honest food.</p>
        </div>
        <div class="footer-links">
          <a href="/">Recipes</a>
          <a href="/about">About</a>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; 2026 The Wooden Spoon. All recipes are original creations by Sarah Chen.</p>
      </div>
    </div>
  </footer>
</body>
</html>
