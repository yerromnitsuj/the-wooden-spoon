<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <meta name="description" content="<%= typeof metaDescription !== 'undefined' ? metaDescription : 'The Wooden Spoon — Simple recipes, real stories, honest food. A food blog by Sarah Chen.' %>">
  <meta name="recipy-verify" content="recipy-verify-162-5b052c0f3be465c20a7a572741208e41">
  <% if (typeof canonicalUrl !== 'undefined' && canonicalUrl) { %>
  <link rel="canonical" href="<%= canonicalUrl %>">
  <% } %>
  <!-- Open Graph -->
  <meta property="og:type" content="<%= typeof ogType !== 'undefined' ? ogType : 'website' %>">
  <meta property="og:title" content="<%= title %>">
  <meta property="og:description" content="<%= typeof metaDescription !== 'undefined' ? metaDescription : 'The Wooden Spoon — Simple recipes, real stories, honest food. A food blog by Sarah Chen.' %>">
  <% if (typeof ogImage !== 'undefined' && ogImage) { %>
  <meta property="og:image" content="<%= ogImage %>">
  <% } %>
  <% if (typeof canonicalUrl !== 'undefined' && canonicalUrl) { %>
  <meta property="og:url" content="<%= canonicalUrl %>">
  <% } %>
  <meta property="og:site_name" content="The Wooden Spoon">
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= title %>">
  <meta name="twitter:description" content="<%= typeof metaDescription !== 'undefined' ? metaDescription : 'The Wooden Spoon — Simple recipes, real stories, honest food. A food blog by Sarah Chen.' %>">
  <% if (typeof ogImage !== 'undefined' && ogImage) { %>
  <meta name="twitter:image" content="<%= ogImage %>">
  <% } %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="nav">
    <div class="container nav-inner">
      <a href="/" class="nav-logo">The Wooden Spoon</a>
      <div class="nav-links">
        <a href="/" class="nav-link<%= currentPath === '/' ? ' active' : '' %>">Recipes</a>
        <a href="/about" class="nav-link<%= currentPath === '/about' ? ' active' : '' %>">About</a>
      </div>
    </div>
  </nav>
